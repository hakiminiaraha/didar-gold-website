# Runtime config for the Docker app container.
# Copy to .env.docker (git-ignored) and fill real values, or run: npm run docker:init
#
# NOTE: VITE_* vars are NOT here — they are compile-time and passed as Docker
# build args (see docker-compose.yml -> services.app.build.args).
#
# NOTE: OTP routing for local compose (OTP_PROVIDER=http -> otp-catcher) is set in
# docker-compose.yml. For real production, set OTP_PROVIDER=payamsms here and add
# the PAYAMSMS_* values below.

# Comma-separated allowed origins for CORS / same-origin checks.
APP_ORIGINS=http://localhost:8787

# Secrets — MUST be >=32 chars in production or the app refuses to boot.
AUTH_HASH_SECRET=change-me-to-a-random-string-at-least-32-chars
SESSION_SECRET=change-me-to-a-different-random-string-32-chars

# Comma-separated admin mobile numbers (granted admin role on login).
ADMIN_MOBILES=09120000000

SESSION_TTL_DAYS=30

# Dev-login: 09123456789 signs in with code 123456 (no SMS). The compose file
# already enables this for the local stack; never enable it in real production.
DEV_LOGIN=true
DEV_LOGIN_MOBILE=09123456789
DEV_LOGIN_CODE=123456

# --- Real production SMS (uncomment + set OTP_PROVIDER=payamsms) ---
# OTP_PROVIDER=payamsms
# PAYAMSMS_BASE_URL=https://www.payamsms.com
# PAYAMSMS_CLIENT_ID=
# PAYAMSMS_CLIENT_SECRET=
# PAYAMSMS_SYSTEM_NAME=
# PAYAMSMS_USERNAME=
# PAYAMSMS_PASSWORD=
# PAYAMSMS_SENDER=
# PAYAMSMS_BODY_TEMPLATE=کد ورود دیدار: {code}
