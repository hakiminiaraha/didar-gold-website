NODE_ENV=production

# Public app origins, comma-separated.
APP_ORIGINS=https://didargold.com,https://www.didargold.com

# Database
# Render Postgres can use DATABASE_SSL=false through its internal connection string.
# Supabase usually requires DATABASE_SSL=true.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_SSL=true
DATABASE_POOL_MAX=5
DATABASE_SEED=true

# Authentication / sessions
AUTH_HASH_SECRET=replace-with-a-strong-64-char-secret
SESSION_SECRET=replace-with-a-strong-64-char-secret
SESSION_TTL_DAYS=30
ADMIN_MOBILES=09120000000

# OTP / SMS
OTP_PROVIDER=payamsms
OTP_TTL_SECONDS=120
OTP_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
PAYAMSMS_BASE_URL=https://www.payamsms.com
PAYAMSMS_CLIENT_ID=
PAYAMSMS_CLIENT_SECRET=
PAYAMSMS_SYSTEM_NAME=
PAYAMSMS_USERNAME=
PAYAMSMS_PASSWORD=
PAYAMSMS_SENDER=
PAYAMSMS_BODY_TEMPLATE=کد ورود دیدار: {code}

# Front-end API
VITE_AUTH_API_URL=/api/auth
VITE_AUTH_DEMO=false

# Marketing tracking. Keep disabled until IDs are verified.
VITE_TRACKING_ENABLED=true
VITE_TRACKING_DEBUG=false
VITE_GA4_MEASUREMENT_ID=
VITE_GTM_ID=
VITE_META_PIXEL_ID=
VITE_LINKEDIN_PARTNER_ID=
VITE_CLARITY_PROJECT_ID=
