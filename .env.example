# Frontend API path. Keep this same-origin in production.
VITE_AUTH_API_URL=/api/auth

# Use true only when intentionally demonstrating the frontend without the API.
VITE_AUTH_DEMO=false

# Marketing and analytics. Keep disabled until real IDs and consent policy are approved.
VITE_TRACKING_ENABLED=false
VITE_TRACKING_DEBUG=false
VITE_GA4_MEASUREMENT_ID=
VITE_GTM_CONTAINER_ID=
VITE_META_PIXEL_ID=
VITE_LINKEDIN_PARTNER_ID=
VITE_CLARITY_PROJECT_ID=

# API server
API_PORT=8787
DATABASE_PATH=server/data/didar.sqlite
# Setting DATABASE_URL switches the API to PostgreSQL. Leave empty for local SQLite.
DATABASE_URL=
DATABASE_SSL=false
DATABASE_POOL_MAX=10
DATABASE_SEED=true
APP_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
NODE_ENV=development

# Replace both values with independent random secrets in every real environment.
AUTH_HASH_SECRET=replace-with-at-least-32-random-characters
SESSION_SECRET=replace-with-another-32-random-characters

# OTP_PROVIDER=console is development-only. Use payamsms for Atieh Dadeh Pardaz REST v2.1.
OTP_PROVIDER=console
OTP_TTL_SECONDS=120
OTP_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
# Per-IP OTP issuance cap (anti-flooding). Window in seconds, max requests per window.
OTP_IP_WINDOW_SECONDS=3600
OTP_IP_MAX_REQUESTS=20
SESSION_TTL_DAYS=30

# Dev-login: when DEV_LOGIN=true, the single mobile DEV_LOGIN_MOBILE signs in with
# the fixed DEV_LOGIN_CODE (no SMS, no rate limit) and gets a real session. For
# local/demo/reviewer use only — leave DEV_LOGIN unset/false in real environments.
DEV_LOGIN=false
DEV_LOGIN_MOBILE=09123456789
DEV_LOGIN_CODE=123456

# Set true only when running behind a trusted reverse proxy (e.g. Render) so the
# real client IP is read from X-Forwarded-For for rate limiting and audit hashes.
TRUST_PROXY=false

# Comma-separated owner mobile numbers. These accounts always remain admins.
# Additional staff roles (support/editor/admin) are managed from the Users tab.
# The dev-login mobile is included so it signs in as admin with code 123456.
ADMIN_MOBILES=09123456789

# Generic provider adapter settings for OTP_PROVIDER=http.
SMS_API_URL=
SMS_API_KEY=
SMS_TEMPLATE=didar-login

# PayamSMS REST v2.1 (https://www.payamsms.com)
# Create Client ID/Secret from the organization's admin panel under "My profile".
PAYAMSMS_BASE_URL=https://www.payamsms.com
PAYAMSMS_CLIENT_ID=
PAYAMSMS_CLIENT_SECRET=
PAYAMSMS_SYSTEM_NAME=
PAYAMSMS_USERNAME=
PAYAMSMS_PASSWORD=
# Dedicated sender number in international format, e.g. 982000...
PAYAMSMS_SENDER=
PAYAMSMS_BODY_TEMPLATE=کد ورود دیدار: {code}

# Optional disposable PostgreSQL database used by the integration smoke test.
TEST_DATABASE_URL=
TEST_DATABASE_SSL=false
