{
  "name": "didar-gold-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.13 <27"
  },
  "scripts": {
    "dev": "vite",
    "dev:api": "node --watch --env-file-if-exists=.env server/index.js",
    "start:api": "node --env-file-if-exists=.env server/index.js",
    "test:api": "node --test --env-file-if-exists=.env server/auth-flow.test.js server/postgres-smoke.test.js",
    "db:migrate:postgres": "node --env-file-if-exists=.env server/migrate-sqlite-to-postgres.js",
    "db:seed:production": "node --env-file-if-exists=.env server/seed-production.js",
    "audit:launch": "node --env-file-if-exists=.env scripts/audit-launch.mjs",
    "audit:production": "node scripts/post-deploy-smoke.mjs",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "focus-trap-react": "^12.0.3",
    "lucide-react": "^1.17.0",
    "pg": "^8.22.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.17.0",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.12"
  }
}
